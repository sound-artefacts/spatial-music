);
(
Out.ar(0,sig11);Out.ar(1,sig12);Out.ar(2,sig13);Out.ar(3,sig14);
Out.ar(0,sig21);Out.ar(1,sig22);Out.ar(2,sig23);Out.ar(3,sig24);
Out.ar(0,sig31);Out.ar(1,sig32);Out.ar(2,sig33);Out.ar(3,sig34);
